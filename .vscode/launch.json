{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONDONTWRITEBYTECODE": "1"
      }
    },
    {
      "name": "PowerShell: Current File",
      "type": "PowerShell",
      "request": "launch",
      "script": "${file}",
      "args": [],
      "createTemporaryIntegratedConsole": true
    }
  ]
}
