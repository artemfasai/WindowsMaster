# Windows Master repository ignore rules
#
# Keep dependency lock files, portable .vscode configuration, sanitized
# examples, backup manifests, and other intentional operational artifacts.

# Secrets and local configuration
.env
.env.*
!.env.example
!.env.sample
!.env.template
.secrets/
secrets/
credentials/
*.key
*.pem
*.p12
*.pfx
*.bek
*.kdbx

# Python environments and generated files
.venv/
venv/
env/
ENV/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/
.ipynb_checkpoints/
build/
dist/
*.egg-info/
.eggs/

# PowerShell test and analysis output
TestResults/
PesterResults*.xml
PSScriptAnalyzerResults*.xml

# .NET and Visual Studio output
.vs/
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Node.js dependencies and generated output
node_modules/
.npm/
.pnpm-store/
.yarn/cache/
.yarn/unplugged/
coverage/

# Runtime logs, diagnostics, and dumps
*.log
*.log.*
*.etl
*.dmp
*.dump
*.stackdump

# Temporary and generated working files
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
*.swp
*.swo
*~
~$*
.cache/
.tmp/
tmp/
temp/

# Local editor state (portable .vscode files remain versionable)
.idea/
.history/
.vscode/*.local.json
*.code-workspace.user

# Windows and macOS metadata
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
._*

# Local sandbox output; retain documentation and placeholders
/Sandbox/*
!/Sandbox/README.md
!/Sandbox/.gitkeep
!/Sandbox/.gitignore

# Runtime log directory; retain documentation, examples, and placeholders
/Logs/*
!/Logs/README.md
!/Logs/*.example
!/Logs/*.sample
!/Logs/.gitkeep
!/Logs/.gitignore
